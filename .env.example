APP_NAME=rs-tool-call
SERVER_ADDR=127.0.0.1:7878
LLM_PROVIDER=openai
OPENAI_API_KEY=your-api-key
LLM_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# SiliconFlow GLM:
# LLM_PROVIDER=siliconflow
# SILICONFLOW_API_KEY=your-siliconflow-api-key
# LLM_MODEL=zai-org/GLM-4.6
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# 阿里百炼 GLM:
# LLM_PROVIDER=glm
# DASHSCOPE_API_KEY=your-bailian-api-key
# LLM_MODEL=glm-5
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MAX_TOOL_ITERATIONS=12
FORM_MARKDOWN_DIR=./forms
# 语音转文字
# MEDIA_TRANSLATE_API_KEY=your-dashscope-api-key
# MEDIA_TRANSLATE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# MEDIA_TRANSLATE_MODEL=qwen3-livetranslate-flash
# FEISHU_CALLBACK_VERIFICATION_TOKEN=your-feishu-verification-token
# FEISHU_CALLBACK_ENCRYPT_KEY=your-feishu-callback-encrypt-key
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=xxx
# FEISHU_OPEN_BASE_URL=https://open.feishu.cn
# FEISHU_BOT_REQUIRE_MENTION=true
# EXEC_COMMAND_TOOL_ENABLED=false
# EXEC_COMMAND_TOOL_SHELL=/bin/sh
# EXEC_COMMAND_TOOL_TIMEOUT_SECS=20
# EXEC_COMMAND_TOOL_MAX_OUTPUT_CHARS=4000
# SYSTEM_PROMPT=You are a tool-calling assistant.

